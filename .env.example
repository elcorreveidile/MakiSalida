# MakiLibre Environment Variables

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Database (Supabase PostgreSQL - Session Pooler for IPv4)
DATABASE_URL="postgresql://postgres.your-project:[PASSWORD]@aws-1-eu-west-2.pooler.supabase.com:5432/postgres"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="MakiLibre <noreply@makilibre.com>"

# Site URL
NEXT_PUBLIC_SITE_URL="https://makilibre.com"

# NOTE: Never commit real .env file with actual values!
# Copy this file to .env.local and fill with real values
