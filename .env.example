# MakiSalida Environment Variables

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@db.xxxx.supabase.co:5432/postgres"

# Authentication (NextAuth.js)
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# OAuth Providers (optional - enable Google login)
GOOGLE_ID=""
GOOGLE_SECRET=""
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED="false"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="MakiSalida <noreply@makisalida.com>"

# Site URL
NEXT_PUBLIC_SITE_URL="https://makisalida.com"

# NOTE: Never commit real .env file with actual values!
# Copy this file to .env.local and fill with real values
