# MakiSalida Environment Variables

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/makisalida"

# Authentication
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (optional)
GITHUB_ID=""
GITHUB_SECRET=""
GOOGLE_ID=""
GOOGLE_SECRET=""

# API Keys
RESEND_API_KEY=""
# Add other API keys as needed

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS="100"
RATE_LIMIT_WINDOW_MS="900000"

# Email
EMAIL_FROM="noreply@makisalida.com"
EMAIL_REPLY_TO="support@makisalida.com"

# Security
ENCRYPTION_KEY=""
JWT_SECRET=""

# Feature Flags
ENABLE_REGISTRATION="true"
ENABLE_DARK_MODE="true"

# Upload
MAX_FILE_SIZE="5242880" # 5MB in bytes
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,application/pdf"

# Redis (for rate limiting and caching)
REDIS_URL="redis://localhost:6379"

# Monitoring (optional)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# NOTE: Never commit real .env file with actual values!
# Copy this file to .env.local and fill with real values
